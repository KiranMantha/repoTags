{
  "manifest_version": 3,
  "name": "GitHub Grouper",
  "version": "1.0.0",
  "description": "Organise your GitHub repos into categories",
  "permissions": ["storage"],
  "action": {
    "default_title": "GitHub Grouper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
